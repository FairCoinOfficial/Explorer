FAIRCOIN_RPC_USER=fair
FAIRCOIN_RPC_PASS=change_me
FAIRCOIN_RPC_HOST=127.0.0.1
FAIRCOIN_RPC_PORT=46373
FAIRCOIN_RPC_SCHEME=http

# MongoDB Configuration
MONGODB_URI=mongodb://localhost:27017/faircoin-explorer

# WebSocket Configuration
WEBSOCKET_ENABLED=true
# Networks the realtime monitor polls (comma-separated: mainnet,testnet).
# Only list networks you actually run a node for.
WEBSOCKET_NETWORKS=mainnet
BLOCKCHAIN_POLL_INTERVAL=10000
WEBSOCKET_HEARTBEAT_INTERVAL=30000
WEBSOCKET_MAX_CONNECTIONS_PER_IP=5
WEBSOCKET_MAX_PAYLOAD_BYTES=65536

# App Configuration
# Public origin allowed by the API CORS allowlist (server-side). Defaults to
# https://explorer.fairco.in when unset.
PUBLIC_BASE_URL=https://explorer.fairco.in

# Reverse proxies whose X-Forwarded-* headers are trusted for client IP rate
# limiting. Leave blank if the API can be reached directly; set comma-separated
# IP/CIDR ranges (for example: 127.0.0.1,10.0.0.0/8,::1) only for proxies that
# overwrite or sanitize X-Forwarded-For before forwarding requests.
TRUSTED_PROXY_CIDRS=
HOST=0.0.0.0
PORT=8080

# GitHub API token (optional). Used by GET /api/github to raise the
# unauthenticated rate limit. Generate a fine-grained read-only token; leave
# blank to use anonymous requests (lower rate limit).
GITHUB_TOKEN=

# Logging
# error | warn | info (default) | debug.
# At info, per-connection / per-broadcast / per-poll chatter is suppressed.
LOG_LEVEL=info
